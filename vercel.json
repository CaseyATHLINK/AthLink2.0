{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @athlink/web build",
  "outputDirectory": "apps/web/dist",
  "functions": {
    "api/sailing/parse_pdf.py": {
      "maxDuration": 60,
      "memory": 3009,
      "includeFiles": "api/_shared/**"
    },
    "api/enrich.py": {
      "maxDuration": 60,
      "includeFiles": "api/_shared/**"
    },
    "api/research_host.py": {
      "maxDuration": 60,
      "includeFiles": "api/_shared/**"
    },
    "api/ai_filter.py": {
      "includeFiles": "api/_shared/**"
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
